# BibleDesk environment variables
# Copy to .env.local for local dev — add the same keys in Render / Vercel project settings.
# Never commit .env.local to git.

# ── Anthropic (Claude) ─────────────────────────────────────────────────────
# Required for all AI answer generation (pipeline stages 1-6)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── OpenAI (RAG embeddings) ────────────────────────────────────────────────
# Required for RAG: generates 1536-dim embeddings via text-embedding-3-small
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Supabase ───────────────────────────────────────────────────────────────
# Public URL + anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Knowledge graph ────────────────────────────────────────────────────────
# Protects POST /api/graph and GET /api/export/obsidian
# Generate with: openssl rand -hex 32
GRAPH_WRITE_SECRET=

# ── Rate limiting ──────────────────────────────────────────────────────────
# Salt for SHA-256 IP hashing (never store raw IPs)
# Generate with: openssl rand -hex 16
IP_HASH_SALT=

# ── App URL ────────────────────────────────────────────────────────────────
# Set to your production URL once deployed (e.g. https://bibledesk.onrender.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Sigil / Discord webhook (Phase 4) ─────────────────────────────────────
# HMAC secret shared with the Sigil Discord bot
# Generate with: openssl rand -hex 32
BIBLEDESK_WEBHOOK_SECRET=
