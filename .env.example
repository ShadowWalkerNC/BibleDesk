# BibleDesk environment variables
# Copy to .env.local for local dev, and add the same keys in Vercel Project Settings.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Knowledge graph write secret (used by POST /api/graph and the pipeline)
# Generate with: openssl rand -hex 32
GRAPH_WRITE_SECRET=
